<Page x:Class="HyperSpinToolkit.Views.AIChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:HyperSpinToolkit.Controls"
    xmlns:effects="clr-namespace:HyperSpinToolkit.Effects"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" Title="AI Chat" d:DesignHeight="800" d:DesignWidth="1200"
    Background="Transparent">

    <Grid>
        <Border Style="{DynamicResource BackgroundLayerStyle}" />
        <effects:ParticleCanvas Preset="NeonRain" MaxParticles="40" SpawnRate="0.8" />

        <Grid Margin="16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="AI CHAT" Style="{DynamicResource ArcadeTitleStyle}" FontSize="22" />
                    <TextBlock Text="NATURAL LANGUAGE → GOOSE ORCHESTRATOR" Style="{DynamicResource ArcadeLabelStyle}" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <controls:LedIndicator LedState="{Binding ViewModel.AgentLedState}" LabelText="GOOSE" LedSize="14" Margin="0,0,16,0" />
                    <controls:LedIndicator LedState="{Binding ViewModel.ModelLedState}" LabelText="LM STUDIO" LedSize="14" />
                </StackPanel>
            </Grid>

            <!-- Chat messages -->
            <Border Grid.Row="1" Style="{DynamicResource ArcadeCardStyle}" Padding="8">
                <ScrollViewer x:Name="ChatScroll" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ViewModel.Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <!-- User message (right-aligned) -->
                                    <Border HorizontalAlignment="{Binding Alignment}"
                                            MaxWidth="600"
                                            CornerRadius="12,12,2,12"
                                            Padding="14,10"
                                            Margin="60,0,0,0"
                                            Background="{Binding BubbleBackground}"
                                            Visibility="{Binding IsUser, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Border.Effect>
                                            <DropShadowEffect Color="{Binding GlowColor}" BlurRadius="8" ShadowDepth="0" Opacity="0.3" />
                                        </Border.Effect>
                                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource NeonWhiteBrush}" FontSize="13" />
                                    </Border>

                                    <!-- AI message (left-aligned) -->
                                    <Border HorizontalAlignment="{Binding Alignment}"
                                            MaxWidth="600"
                                            CornerRadius="12,12,12,2"
                                            Padding="14,10"
                                            Margin="0,0,60,0"
                                            Background="{Binding BubbleBackground}"
                                            Visibility="{Binding IsAI, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Border.Effect>
                                            <DropShadowEffect Color="{Binding GlowColor}" BlurRadius="8" ShadowDepth="0" Opacity="0.3" />
                                        </Border.Effect>
                                        <StackPanel>
                                            <TextBlock Text="{Binding AgentName}" Style="{DynamicResource ArcadeLabelStyle}"
                                                       FontSize="9" Margin="0,0,0,4" />
                                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                                       Style="{DynamicResource ConsoleTextStyle}" FontSize="13" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Input bar -->
            <Border Grid.Row="2" Style="{DynamicResource ArcadeCardStyle}" Padding="8" Margin="0,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" x:Name="ChatInput"
                             Style="{DynamicResource ArcadeTextBoxStyle}"
                             Text="{Binding ViewModel.InputText, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Ask anything about your arcade setup..."
                             AcceptsReturn="False" FontSize="14"
                             VerticalAlignment="Center" />

                    <ComboBox Grid.Column="1" ItemsSource="{Binding ViewModel.AgentModes}"
                              SelectedItem="{Binding ViewModel.SelectedMode}"
                              MinWidth="120" Margin="8,0"
                              VerticalAlignment="Center" />

                    <Button Grid.Column="2" Content="SEND ▶" Style="{DynamicResource ArcadeButtonGreenStyle}"
                            Padding="20,10" FontSize="13"
                            Command="{Binding ViewModel.SendMessageCommand}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
