<Page x:Class="HyperSpinToolkit.Views.CollectionBrowserPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:HyperSpinToolkit.Controls"
    xmlns:effects="clr-namespace:HyperSpinToolkit.Effects"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" Title="Collection Browser" d:DesignHeight="800" d:DesignWidth="1200"
    Background="Transparent">

    <Grid>
        <!-- Layer 0: Video background -->
        <controls:VideoBackground x:Name="BgVideo" OpacityOverlay="0.6" />

        <!-- Layer 1: Particle overlay -->
        <effects:ParticleCanvas Preset="AmbientStars" MaxParticles="60" SpawnRate="1" />

        <!-- Layer 2: Main content -->
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Top bar: System selector -->
            <Border Grid.Row="0" Style="{DynamicResource ArcadeCardStyle}" Margin="16,12,16,0" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="COLLECTION BROWSER" Style="{DynamicResource ArcadeLabelStyle}"
                               VerticalAlignment="Center" Margin="0,0,16,0" />

                    <ComboBox x:Name="SystemSelector" Grid.Column="1"
                              ItemsSource="{Binding ViewModel.Systems}"
                              SelectedItem="{Binding ViewModel.SelectedSystem}"
                              DisplayMemberPath="Name"
                              Style="{DynamicResource ArcadeTextBoxStyle}"
                              MinWidth="250" />

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="16,0,0,0">
                        <controls:LedIndicator LedState="{Binding ViewModel.DriveLedState}" LabelText="DRIVE" LedSize="12" Margin="0,0,16,0" />
                        <controls:ScoreCounter TargetValue="{Binding ViewModel.GameCount}" Prefix="" Suffix=" GAMES"
                                               DigitFontSize="16" Width="160" Height="24" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Center: Wheel Carousel + Preview -->
            <Grid Grid.Row="1" Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <!-- Left: Wheel art carousel -->
                <Border Grid.Column="0" Style="{DynamicResource ArcadeCardStyle}" Padding="0">
                    <Grid>
                        <!-- Wheel art list (vertical carousel) -->
                        <ListBox x:Name="WheelList"
                                 ItemsSource="{Binding ViewModel.WheelArtItems}"
                                 SelectedItem="{Binding ViewModel.SelectedGame}"
                                 Style="{DynamicResource ArcadeListBoxStyle}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="80" Margin="8,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Wheel art image -->
                                        <Border Grid.Column="0" CornerRadius="4" Background="{DynamicResource CabinetSurfaceBrush}">
                                            <Image Source="{Binding WheelArtPath}" Stretch="Uniform" Margin="4" />
                                        </Border>

                                        <!-- Game info -->
                                        <StackPanel Grid.Column="1" Margin="12,8,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding GameName}" Style="{DynamicResource ArcadeSubtitleStyle}"
                                                       FontSize="14" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding SystemName}" Style="{DynamicResource ArcadeLabelStyle}"
                                                       FontSize="10" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Search overlay -->
                        <TextBox x:Name="SearchBox" VerticalAlignment="Top" Margin="8,8"
                                 Style="{DynamicResource ArcadeTextBoxStyle}"
                                 Text="{Binding ViewModel.SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Tag="Search games..." />
                    </Grid>
                </Border>

                <!-- Right: Preview panels -->
                <Grid Grid.Column="1" Margin="12,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Video preview -->
                    <Border Grid.Row="0" Style="{DynamicResource ArcadeCardPinkStyle}" Padding="0" CornerRadius="8">
                        <Grid>
                            <controls:VideoBackground x:Name="PreviewVideo"
                                VideoSource="{Binding ViewModel.SelectedVideoPath}"
                                OpacityOverlay="0.0" IsLooping="True" />
                            <TextBlock Text="VIDEO PREVIEW" Style="{DynamicResource ArcadeLabelStyle}"
                                       VerticalAlignment="Top" HorizontalAlignment="Left" Margin="12,8" />
                        </Grid>
                    </Border>

                    <!-- Box art panels -->
                    <UniformGrid Grid.Row="2" Columns="2">
                        <Border Style="{DynamicResource ArcadeCardStyle}" Margin="0,0,4,0" Padding="4">
                            <Grid>
                                <Image Source="{Binding ViewModel.BoxArt1Path}" Stretch="Uniform" />
                                <TextBlock Text="ARTWORK 1" Style="{DynamicResource ArcadeLabelStyle}"
                                           VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,4" />
                            </Grid>
                        </Border>
                        <Border Style="{DynamicResource ArcadeCardStyle}" Margin="4,0,0,0" Padding="4">
                            <Grid>
                                <Image Source="{Binding ViewModel.BoxArt2Path}" Stretch="Uniform" />
                                <TextBlock Text="ARTWORK 2" Style="{DynamicResource ArcadeLabelStyle}"
                                           VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,4" />
                            </Grid>
                        </Border>
                    </UniformGrid>
                </Grid>
            </Grid>

            <!-- Bottom HUD: Game info bar -->
            <Border Grid.Row="2" Background="{DynamicResource CabinetMidBrush}" Padding="16,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding ViewModel.SelectedGameName}" Style="{DynamicResource PixelTextStyle}"
                                   FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text=" · " Foreground="{DynamicResource NeonBlueBrush}" Opacity="0.5"
                                   VerticalAlignment="Center" Margin="8,0" />
                        <TextBlock Text="{Binding ViewModel.SelectedGenre}" Style="{DynamicResource ArcadeBodyStyle}"
                                   FontSize="11" VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="◀ PREV" Style="{DynamicResource ArcadeButtonStyle}" Padding="12,4" FontSize="11"
                                Command="{Binding ViewModel.PrevGameCommand}" />
                        <Button Content="LAUNCH ▶" Style="{DynamicResource ArcadeButtonGreenStyle}" Padding="16,4" FontSize="11"
                                Command="{Binding ViewModel.LaunchCommand}" Margin="8,0" />
                        <Button Content="NEXT ▶" Style="{DynamicResource ArcadeButtonStyle}" Padding="12,4" FontSize="11"
                                Command="{Binding ViewModel.NextGameCommand}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
