<Page x:Class="HyperSpinToolkit.Views.AssetGalleryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:HyperSpinToolkit.Controls"
    xmlns:effects="clr-namespace:HyperSpinToolkit.Effects"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" Title="Asset Gallery" d:DesignHeight="800" d:DesignWidth="1200"
    Background="Transparent">

    <Grid>
        <Border Style="{DynamicResource BackgroundLayerStyle}" />

        <Grid Margin="16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="ASSET GALLERY" Style="{DynamicResource ArcadeTitleStyle}" FontSize="22" />
                    <TextBlock Style="{DynamicResource ArcadeLabelStyle}" Margin="0,4,0,0">
                        <Run Text="{Binding ViewModel.TotalAssets, StringFormat='{}{0:N0}'}" />
                        <Run Text=" ASSETS ACROSS ALL DRIVES" />
                    </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <controls:ScoreCounter TargetValue="{Binding ViewModel.FilteredCount}" Suffix=" SHOWN"
                                           DigitFontSize="14" Width="140" Height="20" />
                </StackPanel>
            </Grid>

            <!-- Filter bar -->
            <Border Grid.Row="1" Style="{DynamicResource ArcadeCardStyle}" Padding="12,8" Margin="0,0,0,8">
                <WrapPanel>
                    <TextBlock Text="TYPE:" Style="{DynamicResource ArcadeLabelStyle}" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox x:Name="TypeFilter" ItemsSource="{Binding ViewModel.AssetTypes}"
                              SelectedItem="{Binding ViewModel.SelectedType}" MinWidth="140" Margin="0,0,16,0" />

                    <TextBlock Text="SYSTEM:" Style="{DynamicResource ArcadeLabelStyle}" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox x:Name="SystemFilter" ItemsSource="{Binding ViewModel.Systems}"
                              SelectedItem="{Binding ViewModel.SelectedSystem}" MinWidth="160" Margin="0,0,16,0" />

                    <TextBlock Text="DRIVE:" Style="{DynamicResource ArcadeLabelStyle}" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox x:Name="DriveFilter" ItemsSource="{Binding ViewModel.Drives}"
                              SelectedItem="{Binding ViewModel.SelectedDrive}" MinWidth="80" Margin="0,0,16,0" />

                    <TextBlock Text="MIN QUALITY:" Style="{DynamicResource ArcadeLabelStyle}" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <Slider x:Name="QualitySlider" Minimum="0" Maximum="10" Value="{Binding ViewModel.MinQuality}"
                            Width="120" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding ViewModel.MinQuality, StringFormat='{}{0:F1}'}"
                               Style="{DynamicResource PixelTextStyle}" FontSize="12" VerticalAlignment="Center" Margin="0,0,16,0" />

                    <TextBox x:Name="SearchBox" Style="{DynamicResource ArcadeTextBoxStyle}" MinWidth="180"
                             Text="{Binding ViewModel.SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Search..." VerticalAlignment="Center" />
                </WrapPanel>
            </Border>

            <!-- Asset grid -->
            <Border Grid.Row="2" Style="{DynamicResource ArcadeCardStyle}" Padding="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding ViewModel.FilteredAssets}"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="160" Height="140" Margin="4"
                                        Background="{DynamicResource CabinetSurfaceBrush}"
                                        BorderBrush="{DynamicResource CabinetLightBrush}"
                                        BorderThickness="1" CornerRadius="6"
                                        Cursor="Hand"
                                        ToolTip="{Binding ToolTipText}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Thumbnail -->
                                        <Image Grid.Row="0" Source="{Binding ThumbnailPath}" Stretch="Uniform" Margin="4" />

                                        <!-- Info bar -->
                                        <Border Grid.Row="1" Background="{DynamicResource CabinetMidBrush}"
                                                CornerRadius="0,0,6,6" Padding="6,3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding GameName}" FontSize="10"
                                                           Foreground="{DynamicResource NeonWhiteBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1" Text="{Binding QualityScore, StringFormat='{}{0:F1}'}"
                                                           FontSize="10" Foreground="{DynamicResource NeonGreenBrush}" />
                                            </Grid>
                                        </Border>

                                        <!-- Favorite star overlay -->
                                        <TextBlock Text="★" FontSize="16" Foreground="{DynamicResource NeonYellowBrush}"
                                                   HorizontalAlignment="Right" VerticalAlignment="Top" Margin="4"
                                                   Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Bottom: Selected asset details / lightbox trigger -->
            <Border Grid.Row="3" Style="{DynamicResource ArcadeCardStyle}" Padding="10,6" Margin="0,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding ViewModel.SelectedAssetInfo}" Style="{DynamicResource ConsoleTextStyle}"
                                   FontSize="11" VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="★ FAV" Style="{DynamicResource ArcadeButtonOrangeStyle}" Padding="12,4" FontSize="11"
                                Command="{Binding ViewModel.ToggleFavoriteCommand}" Margin="0,0,8,0" />
                        <Button Content="📌 PIN" Style="{DynamicResource ArcadeButtonPinkStyle}" Padding="12,4" FontSize="11"
                                Command="{Binding ViewModel.PinToPageCommand}" Margin="0,0,8,0" />
                        <Button Content="🔍 PREVIEW" Style="{DynamicResource ArcadeButtonStyle}" Padding="12,4" FontSize="11"
                                Command="{Binding ViewModel.PreviewCommand}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
