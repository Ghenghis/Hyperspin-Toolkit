<ui:Page x:Class="HyperSpinToolkit.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:controls="clr-namespace:HyperSpinToolkit.Controls"
    xmlns:effects="clr-namespace:HyperSpinToolkit.Effects"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" Title="Dashboard" Background="Transparent" d:DesignHeight="800" d:DesignWidth="1000">

    <Grid>
        <controls:VideoBackground x:Name="DashboardBgVideo" OpacityOverlay="0.7" />
        <effects:ParticleCanvas Preset="AmbientStars" MaxParticles="50" SpawnRate="1" />

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,20">
            <StackPanel>

                <!-- Page header -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="DASHBOARD" Style="{DynamicResource ArcadeTitleStyle}" FontSize="22" />
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <controls:LedIndicator LedState="{Binding ViewModel.BridgeLedState}" LabelText="BRIDGE" LedSize="10" Margin="0,0,12,0" />
                            <TextBlock Text="{Binding ViewModel.LastRefreshed, StringFormat='Refreshed {0}'}" Style="{DynamicResource ArcadeLabelStyle}" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" VerticalAlignment="Top" Content="REFRESH" Style="{DynamicResource ArcadeButtonStyle}" Padding="14,8" FontSize="11" Command="{Binding ViewModel.RefreshCommand}" IsEnabled="{Binding ViewModel.IsLoading, Converter={StaticResource InverseBoolConverter}}" />
                </Grid>

                <!-- Loading bar -->
                <ProgressBar IsIndeterminate="True" Style="{DynamicResource NeonProgressBarStyle}" Margin="0,0,0,16" Visibility="{Binding ViewModel.IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- Stats cards (Neon arcade style) -->
                <UniformGrid Rows="1" Columns="4" Margin="0,0,0,24">

                    <Border Style="{DynamicResource ArcadeCardStyle}" Margin="0,0,10,0">
                        <StackPanel HorizontalAlignment="Center">
                            <controls:ScoreCounter TargetValue="{Binding ViewModel.TotalSystems}" DigitFontSize="32" Height="40" Width="140" />
                            <TextBlock Text="SYSTEMS" Style="{DynamicResource ArcadeLabelStyle}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource ArcadeCardGreenStyle}" Margin="0,0,10,0">
                        <StackPanel HorizontalAlignment="Center">
                            <controls:ScoreCounter TargetValue="{Binding ViewModel.TotalRoms}" DigitFontSize="32" Height="40" Width="140" />
                            <TextBlock Text="ROMS" Style="{DynamicResource ArcadeLabelStyle}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource ArcadeCardPinkStyle}" Margin="0,0,10,0">
                        <StackPanel HorizontalAlignment="Center">
                            <controls:ScoreCounter TargetValue="{Binding ViewModel.TotalEmulators}" DigitFontSize="32" Height="40" Width="140" />
                            <TextBlock Text="EMULATORS" Style="{DynamicResource ArcadeLabelStyle}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{DynamicResource ArcadeCardStyle}" Margin="0">
                        <StackPanel HorizontalAlignment="Center">
                            <controls:NeonGauge Value="{Binding ViewModel.HealthScoreValue}" Maximum="100" Width="70" Height="70" GaugeMode="Circular" ShowPercentage="True" StrokeThickness="5" />
                            <TextBlock Text="HEALTH" Style="{DynamicResource ArcadeLabelStyle}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <!-- Drive roles -->
                <TextBlock Text="DRIVE ROLES" Style="{DynamicResource ArcadeSubtitleStyle}" Margin="0,0,0,10"/>
                <Border Style="{DynamicResource ArcadeCardStyle}" Padding="0" Margin="0,0,0,24">
                    <DataGrid ItemsSource="{Binding ViewModel.DriveStatuses}" Style="{DynamicResource ArcadeDataGridStyle}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal" HeadersVisibility="Column" RowHeight="38" CanUserResizeRows="False" Background="Transparent" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="100"/>
                            <DataGridTextColumn Header="Drive" Binding="{Binding Letter}" Width="70"/>
                            <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding TotalHuman}" Width="90"/>
                            <DataGridTextColumn Header="Free" Binding="{Binding FreeHuman}" Width="90"/>
                            <DataGridTextColumn Header="Used" Binding="{Binding UsedPct}" Width="65"/>
                            <DataGridTemplateColumn Header="OK" Width="55">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding IsOk, Converter={StaticResource BoolToOkConverter}}" Foreground="{Binding IsOk, Converter={StaticResource BoolToColorConverter}}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="15"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Status -->
                <TextBlock Text="{Binding ViewModel.StatusText}" Style="{DynamicResource ConsoleTextStyle}" FontSize="11" Margin="0,0,0,8" HorizontalAlignment="Right"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:Page>
