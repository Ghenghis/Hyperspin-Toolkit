<ui:Page x:Class="HyperSpinToolkit.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" Title="Dashboard" d:DesignHeight="800" d:DesignWidth="1000">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,20">
        <StackPanel>

            <!-- Page header -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Dashboard" FontSize="28" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center" Fill="{Binding ViewModel.BridgeColor, Converter={StaticResource HexColorToBrushConverter}}"/>
                        <TextBlock Text="{Binding ViewModel.BridgeStatus}" Opacity="0.65" FontSize="12"/>
                        <TextBlock Text=" · " Opacity="0.4" FontSize="12"/>
                        <TextBlock Text="{Binding ViewModel.LastRefreshed, StringFormat='Refreshed {0}'}" Opacity="0.5" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
                <ui:Button Grid.Column="1" VerticalAlignment="Top" Content="Refresh" Icon="{ui:SymbolIcon ArrowSync24}" Command="{Binding ViewModel.RefreshCommand}" IsEnabled="{Binding ViewModel.IsLoading, Converter={StaticResource InverseBoolConverter}}" />
            </Grid>

            <!-- Loading bar -->
            <ProgressBar IsIndeterminate="True" Height="3" Margin="0,0,0,16" Visibility="{Binding ViewModel.IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Stats cards -->
            <UniformGrid Rows="1" Columns="4" Margin="0,0,0,24">

                <ui:Card Margin="0,0,10,0" Padding="20">
                    <StackPanel>
                        <ui:SymbolIcon Symbol="Desktop24" FontSize="26" Opacity="0.6" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding ViewModel.TotalSystems}" FontSize="38" FontWeight="Bold" Margin="0,6,0,0"/>
                        <TextBlock Text="Systems" Opacity="0.55" FontSize="13"/>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,10,0" Padding="20">
                    <StackPanel>
                        <ui:SymbolIcon Symbol="Games24" FontSize="26" Opacity="0.6" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding ViewModel.TotalRoms, StringFormat='{}{0:N0}'}" FontSize="38" FontWeight="Bold" Margin="0,6,0,0"/>
                        <TextBlock Text="ROMs" Opacity="0.55" FontSize="13"/>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0,0,10,0" Padding="20">
                    <StackPanel>
                        <ui:SymbolIcon Symbol="Apps24" FontSize="26" Opacity="0.6" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding ViewModel.TotalEmulators}" FontSize="38" FontWeight="Bold" Margin="0,6,0,0"/>
                        <TextBlock Text="Emulators" Opacity="0.55" FontSize="13"/>
                    </StackPanel>
                </ui:Card>

                <ui:Card Margin="0" Padding="20">
                    <StackPanel>
                        <ui:SymbolIcon Symbol="Heart24" FontSize="26" HorizontalAlignment="Left" Foreground="{Binding ViewModel.HealthColor, Converter={StaticResource HexColorToBrushConverter}}"/>
                        <TextBlock Text="{Binding ViewModel.HealthScore}" FontSize="38" FontWeight="Bold" Margin="0,6,0,0" Foreground="{Binding ViewModel.HealthColor, Converter={StaticResource HexColorToBrushConverter}}"/>
                        <TextBlock Text="Health Score" Opacity="0.55" FontSize="13"/>
                    </StackPanel>
                </ui:Card>

            </UniformGrid>

            <!-- Drive roles -->
            <TextBlock Text="Drive Roles" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,10"/>
            <ui:Card Padding="0" Margin="0,0,0,24">
                <DataGrid ItemsSource="{Binding ViewModel.DriveStatuses}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal" HeadersVisibility="Column" RowHeight="38" CanUserResizeRows="False" Background="Transparent" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="100"/>
                        <DataGridTextColumn Header="Drive" Binding="{Binding Letter}" Width="70"/>
                        <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*"/>
                        <DataGridTextColumn Header="Total" Binding="{Binding TotalHuman}" Width="90"/>
                        <DataGridTextColumn Header="Free" Binding="{Binding FreeHuman}" Width="90"/>
                        <DataGridTextColumn Header="Used" Binding="{Binding UsedPct}" Width="65"/>
                        <DataGridTemplateColumn Header="OK" Width="55">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding IsOk, Converter={StaticResource BoolToOkConverter}}" Foreground="{Binding IsOk, Converter={StaticResource BoolToColorConverter}}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="15"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </ui:Card>

            <!-- Status -->
            <TextBlock Text="{Binding ViewModel.StatusText}" Opacity="0.55" FontSize="12" Margin="0,0,0,8" HorizontalAlignment="Right"/>

        </StackPanel>
    </ScrollViewer>
</ui:Page>
