<Page x:Class="HyperSpinToolkit.Views.AgentConsolePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:HyperSpinToolkit.Controls"
    xmlns:effects="clr-namespace:HyperSpinToolkit.Effects"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" Title="Agent Console" d:DesignHeight="800" d:DesignWidth="1200"
    Background="Transparent">

    <Grid>
        <!-- Background -->
        <Border Style="{DynamicResource BackgroundLayerStyle}" />

        <!-- Content -->
        <Grid Margin="16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="AGENT CONSOLE" Style="{DynamicResource ArcadeTitleStyle}" FontSize="22" />
                    <TextBlock Text="Goose · NemoClaw · OpenHands · CLI-Anything" Style="{DynamicResource ArcadeLabelStyle}" Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="CLEAR" Style="{DynamicResource ArcadeButtonStyle}" Padding="14,6" FontSize="11"
                            Command="{Binding ViewModel.ClearCommand}" Margin="0,0,8,0" />
                    <Button Content="EXPORT LOG" Style="{DynamicResource ArcadeButtonPinkStyle}" Padding="14,6" FontSize="11"
                            Command="{Binding ViewModel.ExportCommand}" />
                </StackPanel>
            </Grid>

            <!-- Agent status LEDs -->
            <Border Grid.Row="1" Style="{DynamicResource ArcadeCardStyle}" Padding="12,8" Margin="0,0,0,8">
                <WrapPanel>
                    <controls:LedIndicator LedState="{Binding ViewModel.GooseState}" LabelText="GOOSE" LedSize="14" Margin="0,0,24,0" />
                    <controls:LedIndicator LedState="{Binding ViewModel.NemoClawState}" LabelText="NEMOCLAW" LedSize="14" Margin="0,0,24,0" />
                    <controls:LedIndicator LedState="{Binding ViewModel.OpenHandsState}" LabelText="OPENHANDS" LedSize="14" Margin="0,0,24,0" />
                    <controls:LedIndicator LedState="{Binding ViewModel.CliAnythingState}" LabelText="CLI-ANYTHING" LedSize="14" Margin="0,0,24,0" />
                    <controls:LedIndicator LedState="{Binding ViewModel.SecurityState}" LabelText="SECURITY" LedSize="14" Margin="0,0,24,0" />
                    <controls:LedIndicator LedState="{Binding ViewModel.McpBridgeState}" LabelText="MCP BRIDGE" LedSize="14" />
                </WrapPanel>
            </Border>

            <!-- CRT Terminal -->
            <Border Grid.Row="2" Style="{DynamicResource ArcadeCardStyle}" Padding="0" CornerRadius="8">
                <controls:CrtTerminal x:Name="Terminal"
                    MaxLines="1000"
                    ShowScanLines="True"
                    FontSizeTerminal="13"
                    Prompt="λ " />
            </Border>

            <!-- Command input -->
            <Border Grid.Row="3" Style="{DynamicResource ArcadeCardStyle}" Padding="8" Margin="0,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="λ" Style="{DynamicResource PixelTextStyle}" FontSize="16"
                               VerticalAlignment="Center" Margin="4,0,8,0" />

                    <TextBox Grid.Column="1" x:Name="CommandInput"
                             Style="{DynamicResource ArcadeTextBoxStyle}"
                             Text="{Binding ViewModel.CommandText, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Enter command or natural language query..."
                             VerticalAlignment="Center" />

                    <ComboBox Grid.Column="2" x:Name="AgentSelector"
                              ItemsSource="{Binding ViewModel.AvailableAgents}"
                              SelectedItem="{Binding ViewModel.SelectedAgent}"
                              MinWidth="140" Margin="8,0"
                              VerticalAlignment="Center" />

                    <Button Grid.Column="3" Content="SEND ▶" Style="{DynamicResource ArcadeButtonGreenStyle}"
                            Padding="16,8" FontSize="12"
                            Command="{Binding ViewModel.SendCommand}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
