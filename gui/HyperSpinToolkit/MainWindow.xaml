<ui:FluentWindow x:Class="HyperSpinToolkit.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:views="clr-namespace:HyperSpinToolkit.Views" Title="HyperSpin Extreme Toolkit" Width="1280" Height="800" MinWidth="900" MinHeight="600" WindowStartupLocation="CenterScreen" ExtendsContentIntoTitleBar="True">

    <Grid>
        <ui:NavigationView x:Name="RootNavigation" PaneDisplayMode="Left" IsPaneOpen="True" OpenPaneLength="220">

            <!-- Header shown above nav items -->
            <ui:NavigationView.Header>
                <StackPanel Margin="16,12">
                    <TextBlock Text="HyperSpin" FontSize="14" FontWeight="Bold" Opacity="0.9"/>
                    <TextBlock Text="Extreme Toolkit" FontSize="11" Opacity="0.55"/>
                </StackPanel>
            </ui:NavigationView.Header>

            <!-- Sidebar items -->
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem x:Name="NavDashboard" Content="Dashboard" TargetPageType="{x:Type views:DashboardPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Home24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem x:Name="NavCollection" Content="Collection" TargetPageType="{x:Type views:CollectionBrowserPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Games24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem x:Name="NavGallery" Content="Asset Gallery" TargetPageType="{x:Type views:AssetGalleryPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Image24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem x:Name="NavDrives" Content="Drives" TargetPageType="{x:Type views:DrivesPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="HardDrive24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem x:Name="NavAudit" Content="Audit" TargetPageType="{x:Type views:AuditPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="ClipboardSearch24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem x:Name="NavBackup" Content="Backup" TargetPageType="{x:Type views:BackupPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="ArrowDownload24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem x:Name="NavAgents" Content="Agent Console" TargetPageType="{x:Type views:AgentConsolePage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Bot24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>

                <ui:NavigationViewItem x:Name="NavChat" Content="AI Chat" TargetPageType="{x:Type views:AIChatPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Chat24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <!-- Footer items -->
            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem x:Name="NavSettings" Content="Settings" TargetPageType="{x:Type views:SettingsPage}">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Settings24" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.FooterMenuItems>

        </ui:NavigationView>
    </Grid>
</ui:FluentWindow>
